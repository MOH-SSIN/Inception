1) nginx 
+ Dockerfile
"

FROM debian:bookworm

RUN apt-get update && apt-get install -y \
nginx \
openssl \
&& rm -rf /var/lib/apt/lists/*

EXPOSE 443

RUN mkdir -p /etc/nginx/ssl

RUN openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
    -keyout /etc/nginx/ssl/nginx.key \
    -out /etc/nginx/ssl/nginx.crt \
    -subj "/C=CA/ST=QC/L=Quebec/O=42/OU=42/CN=mez-zahi.42.fr" 

RUN rm -f /etc/nginx/sites-enabled/default

COPY conf/nginx.conf /etc/nginx/sites-available/default 

RUN ln -s /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

RUN echo "<h1>I LOVE YOU <3 </h1>" > /var/www/html/wlcm.html

CMD ["nginx", "-g", "daemon off;"]
# ENTRYPOINT ["nginx", "-g", "daemon off;"]

"
+nginx.conf
"
server
{
    listen 443 ssl;
    server_name mez-zahi.42.fr;
    
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_certificate /etc/nginx/ssl/nginx.crt;
    ssl_certificate_key /etc/nginx/ssl/nginx.key;

    root /var/www/html;

    index index.php ;

    location ~ \.php$
    {
            fastcgi_pass wordpress:9000;
            fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
            include fastcgi_params;
    }

    # location / {
    #     try_files $uri $uri/ =404;
    # }
}
"

2) mariadb
+Dockerfile
"
FROM debian:bookworm

RUN apt-get update && apt-get install -y mariadb-server && rm -rf /var/lib/apt/lists/*

EXPOSE 3306

COPY tools/mariadb.sh /mariadb.sh
RUN chmod +x /mariadb.sh

# On utilise ENTRYPOINT pour que le script soit le processus principal
ENTRYPOINT [ "/mariadb.sh" ]


"

+mariadb.sh
"
#!/bin/bash

# DГ©marrer MariaDB en arriГЁre-plan pour la configuration
mysqld_safe --datadir=/var/lib/mysql &

# Attendre que MariaDB soit prГЄt (on vГ©rifie s'il rГ©pond au ping)
until mysqladmin ping -h "127.0.0.1" --silent; do
    echo "Attente de MariaDB..."
    sleep 1
done

# echo "<-----1---->"
# mysqlshow -u root

# Configuration initiale (seulement si la DB n'existe pas dГ©jГ )
if [ ! -d "/var/lib/mysql/${MYSQL_DATABASE}" ]; then
    echo "Configuration de la base de donnГ©es..."

    # 1. CrГ©er la database
    mysql -e "CREATE DATABASE IF NOT EXISTS \`${MYSQL_DATABASE}\`;"

    # 2. CrГ©er l'utilisateur SQL pour WordPress
    mysql -e "CREATE USER IF NOT EXISTS \`${MYSQL_USER}\`@'%' IDENTIFIED BY '${MYSQL_PASSWORD}';"

    # 3. Donner les droits
    mysql -e "GRANT ALL PRIVILEGES ON \`${MYSQL_DATABASE}\`.* TO \`${MYSQL_USER}\`@'%';"

fi
# echo "<-----2---->"
# mysqlshow -u root

echo "MariaDB est prГЄt et configurГ© !"

# ArrГЄter proprement le service temporaire
# mysqladmin -u root -p${MYSQL_ROOT_PASSWORD} shutdown
mysqladmin shutdown

# Relancer MariaDB au premier plan (pour garder le conteneur ouvert)
# Le bind-address=0.0.0.0 permet aux autres conteneurs de se connecter
exec mysqld_safe --datadir=/var/lib/mysql --bind-address=0.0.0.0
"

3) wordpress
+Dockerfile
"
FROM debian:bookworm

RUN apt-get update && apt-get install -y \
    wget \
    php8.2-fpm \
    php8.2-mysql \
    php8.2-curl \
    default-mysql-client \
    && rm -rf /var/lib/apt/lists/*

COPY tools/setup.sh /usr/local/bin/

RUN mkdir -p  /var/www/html

RUN mkdir -p /run/php && chown www-data:www-data /run/php

RUN chmod +x /usr/local/bin/setup.sh

RUN sed -i 's/listen = \/run\/php\/php8.2-fpm.sock/listen = 0.0.0.0:9000/' /etc/php/8.2/fpm/pool.d/www.conf
# RUN sed -i 's/listen = \/run\/php\/php8.2-fpm.sock/listen = 9000/g' /etc/php/8.2/fpm/pool.d/www.conf

EXPOSE 9000

WORKDIR /var/www/html

ENTRYPOINT ["/usr/local/bin/setup.sh"]
# CMD ["/usr/local/bin/setup.sh"]
"
+setup.sh
"
#!/bin/bash

until mysql -h mariadb -u"${MYSQL_USER}" -p"${MYSQL_PASSWORD}" -e "SELECT 1;" >/dev/null 2>&1; do
    echo "MariaDB not ready, waiting..."
    sleep 1
done
echo "MariaDB is ready!"

if [ ! -f "/var/www/html/wp-config.php" ]; then

    wget https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar -O /usr/local/bin/wp
    chmod +x /usr/local/bin/wp
    cd /var/www/html
    wp core download --allow-root 
    mv wp-config-sample.php wp-config.php
    wp config set DB_NAME "${MYSQL_DATABASE}" --allow-root
    wp config set DB_USER "${MYSQL_USER}" --allow-root
    wp config set DB_PASSWORD "${MYSQL_PASSWORD}" --allow-root
    wp config set DB_HOST "mariadb" --allow-root
    echo "hhhhhh"

    wp core install \
        --url="${DOMAIN_NAME}" \
        --title="Inception WordPress" \
        --admin_user="${WP_ADMIN_USER}" \
        --admin_password="${WP_ADMIN_PASSWORD}" \
        --admin_email="${WP_ADMIN_EMAIL}" \
        --allow-root

    wp user create \
        "${WP_USER}" \
        "${WP_USER_EMAIL}" \
        --user_pass="${WP_USER_PASSWORD}" \
        --role=author \
        --allow-root
fi

chown -R www-data:www-data /var/www/html

exec php-fpm8.2 -F
"
